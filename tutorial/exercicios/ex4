#include "raylib.h"

int main()
{
    InitWindow(800, 600, "FPS Example");

    SetTargetFPS(120);

    int x1 = 0;
    int x2 = 2;

    while (!WindowShouldClose())
    {
        x1 += 2;
        x2 += 10;

        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawRectangle(x1, 250, 100, 100, BLUE);
        DrawRectangle(x2, 400, 100, 50, RED);

        DrawText("FPS Example", 10, 10, 20, BLACK);

        DrawFPS(700, 10);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
