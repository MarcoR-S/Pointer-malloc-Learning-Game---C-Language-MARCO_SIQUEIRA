
#include "raylib.h"

int main()
{
    InitWindow(800, 600, "Meu Primeiro Jogo");

    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(SKYBLUE);

        DrawText("Meu Primeiro Jogo", 10, 10, 40, BLACK);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
